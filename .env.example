# ===================================================================
# Local Development Runtime
# Used when running the app locally on 127.0.0.1
# ===================================================================

VITE_APP_URL=http://127.0.0.1:5173
VITE_API_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:3000
CUSTOMER_APP_URL=http://127.0.0.1:5173
ADMIN_APP_URL=http://127.0.0.1:5173/admin

# ===================================================================
# Production Domain Mapping Reference
# Use these values when creating Vercel and Railway apps
# ===================================================================

CUSTOMER_PROD_URL=https://theinvoicepro.co.za
ADMIN_PROD_URL=https://admin.theinvoicepro.co.za
API_PROD_URL=https://api.theinvoicepro.co.za

# ===================================================================
# Supabase
# Frontend uses VITE_ vars.
# API/Railway should use plain server-side vars.
# ===================================================================

SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BRANDING_BUCKET=company-branding

# ===================================================================
# Customer Frontend Auth0
# Vercel app: https://theinvoicepro.co.za
# ===================================================================

VITE_CUSTOMER_AUTH0_DOMAIN=your-customer-auth0-domain
VITE_CUSTOMER_AUTH0_CLIENT_ID=your-customer-auth0-client-id
VITE_CUSTOMER_AUTH0_AUDIENCE=https://api.theinvoicepro.co.za
VITE_CUSTOMER_AUTH0_REDIRECT_URI=http://127.0.0.1:5173/auth/callback
VITE_CUSTOMER_AUTH0_CONNECTION=Username-Password-Authentication

# ===================================================================
# Admin Frontend Auth0
# Vercel app: https://admin.theinvoicepro.co.za
# ===================================================================

VITE_ADMIN_AUTH0_DOMAIN=your-admin-auth0-domain
VITE_ADMIN_AUTH0_CLIENT_ID=your-admin-auth0-client-id
VITE_ADMIN_AUTH0_AUDIENCE=https://api.theinvoicepro.co.za
VITE_ADMIN_AUTH0_REDIRECT_URI=http://127.0.0.1:5173/admin/callback
VITE_ADMIN_AUTH0_CONNECTION=Username-Password-Authentication

# Production callback reference:
# VITE_ADMIN_AUTH0_REDIRECT_URI=https://admin.theinvoicepro.co.za/callback

# ===================================================================
# Shared frontend Auth0 settings
# ===================================================================

VITE_AUTH0_ROLE_CLAIM=https://theinvoicepro.co.za/roles
VITE_AUTH_MODE=auth0
VITE_PAYMENT_PROVIDER=payfast

# ===================================================================
# Railway API Auth0
# API domain: https://api.theinvoicepro.co.za
# ===================================================================

AUTH0_DOMAIN=your-auth0-domain
AUTH0_AUDIENCE=https://api.theinvoicepro.co.za

# ===================================================================
# Resend
# API-side email delivery
# ===================================================================

RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@theinvoicepro.co.za

# ===================================================================
# PayFast
# Server-only. Do not expose these to Vercel/frontend envs.
# ===================================================================

PAYFAST_MERCHANT_ID=your-merchant-id
PAYFAST_MERCHANT_KEY=your-merchant-key
PAYFAST_PASSPHRASE=your-passphrase
PAYFAST_MODE=sandbox
PAYFAST_NOTIFY_URL=https://api.theinvoicepro.co.za/payfast/webhook

# ===================================================================
# Paystack
# Server-only for redirect checkout and transaction verification.
# Set VITE_PAYMENT_PROVIDER=paystack on the frontend when testing Paystack.
# ===================================================================

PAYMENT_PROVIDER=payfast
PAYSTACK_PUBLIC_KEY=paystack_public_test_key_here
PAYSTACK_SECRET_KEY=paystack_secret_test_key_here
PAYSTACK_WEBHOOK_SECRET=paystack_webhook_secret_here
PAYSTACK_CALLBACK_URL=https://theinvoicepro.co.za/auth/card-setup/success?provider=paystack

# Note: Never commit your actual .env file with real credentials.

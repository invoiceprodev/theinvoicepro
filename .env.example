# Supabase Configuration
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/YOUR_PROJECT_ID/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public API key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# EmailJS Configuration
# Get these values from your EmailJS account:
# https://dashboard.emailjs.com/admin

# Your EmailJS Public Key (User ID)
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# Your EmailJS Service ID
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id

# Your EmailJS Template ID for invoice emails
VITE_EMAILJS_TEMPLATE_ID=your-emailjs-template-id

# PayFast Configuration
# Get these values from your PayFast merchant account:
# https://www.payfast.co.za/

# Your PayFast Merchant ID
VITE_PAYFAST_MERCHANT_ID=your-merchant-id

# Your PayFast Merchant Key
VITE_PAYFAST_MERCHANT_KEY=your-merchant-key

# Your PayFast Passphrase (set in your PayFast account settings)
VITE_PAYFAST_PASSPHRASE=your-passphrase

# PayFast environment mode (sandbox or live)
VITE_PAYFAST_MODE=sandbox

# PayFast API URLs (for subscription/recurring payments)
VITE_PAYFAST_API_URL=https://api.payfast.co.za
VITE_PAYFAST_SANDBOX_API_URL=https://api.sandbox.payfast.co.za

# Note: Never commit your actual .env file with real credentials to version control
# The .env file is already in .gitignore
